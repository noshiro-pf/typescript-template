{
  "extends": "./tsconfig.type-check.json",
  "compilerOptions": {
    // Emit
    // Note: "downlevelIteration" and "importsNotUsedAsValues" were removed
    // because they are deprecated in TypeScript 6.0 (TS5101) and will stop
    // functioning in 7.0. "downlevelIteration" is a no-op with
    // "target": "ESNext", and "importsNotUsedAsValues": "remove" was the
    // default behavior. "importHelpers" was removed together with the "tslib"
    // dependency: this config is now used for declaration emit only (via the
    // native tsc), and JS transpilation is done by esbuild, which inserts its
    // own helpers inline.
    "newLine": "lf",
    "noEmit": false,
    "noEmitOnError": true,

    // Projects
    "incremental": false
  }
}
